{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm:build",
      "type": "process",
      "command": "npm",
      "args": [
        "run",
        "build"
      ],
      "detail": "Builds the entire Nx workspace.",
      "group": "build",
      "isBackground": false,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "showReuseMessage": false,
        "close": false,
        "panel": "dedicated"
      },
      "options": {
        "env": {
          "CI": "true"
        }
      }
    },
    {
      "label": "npm:lint",
      "type": "process",
      "command": "npm",
      "args": [
        "run",
        "lint"
      ],
      "detail": "Runs linting across the workspace.",
      "group": "build",
      "isBackground": false,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "showReuseMessage": false,
        "close": false,
        "panel": "dedicated"
      },
      "options": {
        "env": {
          "CI": "true"
        }
      }
    },
    {
      "label": "npm:test",
      "type": "process",
      "command": "npm",
      "args": [
        "run",
        "test",
        "--",
        "--watch=false",
        "--code-coverage"
      ],
      "detail": "Runs all tests with watch disabled and code coverage enabled.",
      "group": "test",
      "isBackground": false,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "showReuseMessage": false,
        "close": false,
        "panel": "dedicated"
      },
      "options": {
        "env": {
          "CI": "true"
        }
      }
    }
  ]
}
